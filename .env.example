# Copy this file to `.env` and fill in your values for LOCAL runs (VS Code).
# For the GitHub Actions deployment you do NOT use this file — you set the same
# names as repository Secrets instead (see README_DEPLOY.md).

# Required: your The Odds API key (rotate it if it's ever been exposed).
ODDS_API_KEY=your_odds_api_key_here

# Optional (Google Sheet output). Leave WC_SHEET_ID blank to write JSON/CSV only.
WC_SHEET_ID=
WC_SHEET_TAB=closing_lines
# Either the path to your service-account key file, or the raw JSON on one line.
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# Optional tuning.
WC_SPORT_KEY=soccer_fifa_world_cup
WC_MARKETS=h2h,spreads,totals
WC_DATA_DIR=data
# Only capture matches kicked off within this many hours (0 = no limit).
WC_LOOKBACK_HOURS=0
